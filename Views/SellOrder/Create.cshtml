@model MedicalStore.ViewModels.SellOrderViewModel
@{
    ViewData["Title"] = "Create Sell Order";
    var clients = ViewBag.Clients as List<MedicalStore.Models.Client>;
}

<h2>Create Sell Order</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (TempData["CancelMessage"] != null)
{
    <div class="alert alert-warning">@TempData["CancelMessage"]</div>
}

<form asp-action="SubmitOrder" method="post">
    <div class="form-group">
        <label>Select Client</label>
        <select asp-for="ClientId" class="form-control" asp-items="@(new SelectList(clients, "Id", "ClientName"))">
            <option value="">-- Select Client --</option>
        </select>
        <span asp-validation-for="ClientId" class="text-danger"></span>
    </div>

    @for (int i = 0; i < Model.Items.Count; i++)
    {
        <div class="form-group">
            <label>Medicine</label>
            <select asp-for="Items[@i].MedicineName" class="form-control" asp-items="@(new SelectList(ViewBag.Medicines))">
                <option value="">-- Select Medicine --</option>
            </select>
        </div>

        <div class="form-group">
            <label>Quantity</label>
            <input asp-for="Items[@i].Quantity" class="form-control" />
        </div>

        <div class="form-group">
            <label>Price</label>
            <input asp-for="Items[@i].Price" class="form-control" />
        </div>
        <hr />
    }

    <button type="submit" class="btn btn-primary">Submit Order</button>
</form>

<form asp-action="CancelOrder" method="post" style="margin-top:10px;">
    <button type="submit" class="btn btn-danger">Cancel Order</button>
</form>
