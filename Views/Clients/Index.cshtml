@model IEnumerable<MedicalStore.Models.Client>
@{
    ViewData["Title"] = "Clients";
}
<h2>Client List</h2>
<a asp-action="Create" class="btn btn-primary">Add New Client</a>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Gender</th>
            <th>Address</th>
            <th>City</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.ClientName</td>
                <td>@c.Gender</td>
                <td>@c.Address</td>
                <td>@c.City</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@c.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@c.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@c.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
